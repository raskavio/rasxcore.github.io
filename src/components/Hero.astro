---
import { Image } from 'astro:assets';
import heroAvatar from '../assets/hero-avatar.jpg';
import { defaultLang, t } from '../i18n';

const lang = defaultLang;
---

<header class="px-0 pb-7 pt-5 text-center">
	<div class="relative mx-auto mb-4 h-[5.5rem] w-[5.5rem]">
		<Image
			class="panel-avatar relative z-[1] h-full w-full rounded-full border-[3px] object-cover"
			src={heroAvatar}
			alt=""
			width={88}
			height={88}
			densities={[1, 2]}
			priority
		/>
		<span
			class="panel-avatar-glow animate-avatar-glow absolute -inset-1.5 rounded-full"
			aria-hidden="true"
		></span>
	</div>
	<h1
		class="panel-text mb-2 font-display text-[1.75rem] font-bold tracking-wide"
		data-i18n="hero.name"
	>
		{t(lang, 'hero.name')}
	</h1>
	<p
		class="panel-text-accent mb-2.5 text-sm font-medium leading-snug"
		data-i18n="hero.tagline"
	>
		{t(lang, 'hero.tagline')}
	</p>
	<p
		class="panel-text-muted w-full text-justify text-[0.9375rem]"
		data-i18n="hero.subtitle"
	>
		{t(lang, 'hero.subtitle')}
	</p>
</header>
